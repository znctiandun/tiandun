    def _build_embed_url(self, source: str, video_id: str) -> str:
        """构建视频嵌入 URL"""
        if source == 'youtube':
            return f"https://www.youtube.com/embed/{video_id}"
        elif source == 'bilibili':
            return f"https://player.bilibili.com/player.html?bvid={video_id}&page=1&high_quality=1"
        elif source == 'tencent':
            return f"https://v.qq.com/txp/iframe/player.html?vid={video_id}&auto=0"
        elif source == 'youku':
            return f"https://player.youku.com/embed/{video_id}"
        else:
            return f"https://www.youtube.com/embed/{video_id}"
    
    def _render_tags(self, tags: List[str]) -> str:
        """渲染标签"""
        if not tags:
            return ''
        
        tag_html = '<div style="display: flex; gap: 8px; flex-wrap: wrap;">'
        for tag in tags:
            tag_html += f"""
            <span style="
                background: rgba(255,255,255,0.15);
                padding: 4px 10px;
                border-radius: 12px;
                font-size: 11px;
                color: white;
            ">
                #{tag}
            </span>
            """
        tag_html += '</div>'
        return tag_html
    
    def create_video_sentiment_chart(self, videos: List[Dict]) -> 'go.Figure':
        """创建视频情感分布图"""
        import plotly.graph_objects as go
        
        if not videos:
            return go.Figure()
        
        sentiment_counts = {'positive': 0, 'neutral': 0, 'negative': 0}
        for video in videos:
            sentiment = video.get('sentiment', 'neutral')
            sentiment_counts[sentiment] = sentiment_counts.get(sentiment, 0) + 1
        
        fig = go.Figure(data=[go.Pie(
            labels=['正面', '中性', '负面'],
            values=[sentiment_counts['positive'], sentiment_counts['neutral'], sentiment_counts['negative']],
            marker_colors=['#66BB6A', '#FFCA28', '#EF5350']
        )])
        
        fig.update_layout(
            title='视频情感分布',
            height=300,
            showlegend=True
        )
        
        return fig
