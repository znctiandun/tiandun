    def __init__(self, stock_code: str, stock_name: str):
        self.stock_code = stock_code
        self.stock_name = stock_name
        self.video_cache = {}
    
    def get_stock_videos(self, category: str = 'all') -> List[Dict]:
        """获取与股票相关的视频列表"""
        if self.stock_code in self.VIDEO_TEMPLATES:
            videos = self.VIDEO_TEMPLATES[self.stock_code]
        else:
            videos = [
                {**template, 'title': template['title'].format(stock_name=self.stock_name)}
                for template in self.VIDEO_TEMPLATES['default']
            ]
        
        if category != 'all':
            videos = [v for v in videos if v.get('category') == category]
        
        return videos
    
    def get_macro_videos(self, tags: List[str] = None) -> List[Dict]:
        """获取宏观新闻视频"""
        videos = self.MACRO_VIDEOS.copy()
        
        if tags:
            filtered = []
            for video in videos:
                video_tags = video.get('tags', [])
                if any(tag in video_tags for tag in tags):
                    filtered.append(video)
            videos = filtered if filtered else videos
        
        return videos
    
