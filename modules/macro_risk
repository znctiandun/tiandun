class MacroRiskAnalyzer:
    """宏观风险分析器"""
    
    # 政策风险关键词
    POLICY_RISK_KEYWORDS = {
        'high_risk': [
            '限制', '禁止', '整顿', '处罚', '监管', '打击', '清理', '取缔',
