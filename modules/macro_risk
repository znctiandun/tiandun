        'medium_risk': [
            '规范', '引导', '调整', '优化', '完善', '加强', '提高', '严格'
        ],
        'low_risk': [
            '支持', '鼓励', '促进', '发展', '扶持', '优惠', '减免', '创新'
        ]
    }
    
    # 行业政策敏感度
    INDUSTRY_POLICY_SENSITIVITY = {
        '白酒': {'sensitivity': 0.7, 'key_policies': ['消费税', '三公消费', '限酒令']},
        '新能源': {'sensitivity': 0.9, 'key_policies': ['补贴', '碳中和', '产能']},
        '医药': {'sensitivity': 0.85, 'key_policies': ['集采', '医保', '创新药']},
        '互联网': {'sensitivity': 0.95, 'key_policies': ['反垄断', '数据安全', '教育']},
        '房地产': {'sensitivity': 0.9, 'key_policies': ['限购', '限贷', '三道红线']},
        '金融': {'sensitivity': 0.8, 'key_policies': ['利率', '监管', '资本充足率']},
        '能源': {'sensitivity': 0.75, 'key_policies': ['油价', '碳排放', '环保']},
